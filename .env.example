# Copie este arquivo para .env e preencha com a sua chave.
# O .env está no .gitignore -> NUNCA vai pro GitHub.
#
#   cp .env.example .env        (Linux/Mac)
#   copy .env.example .env      (Windows)

# Chave da API da Anthropic (pegue em https://console.anthropic.com)
# Sem ela, o chat roda em modo offline (texto-modelo) e o app NÃO quebra.
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui

# Opcional: modelo do Claude (padrão: claude-sonnet-4-6)
# COTIDIANO_MODEL=claude-sonnet-4-6
